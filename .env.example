# ========================================
# VARIÁVEIS DE AMBIENTE - MERCADO PAGO
# ========================================

# [MERCADO PAGO DEBUG] Token de acesso do Mercado Pago
# IMPORTANTE: 
# - Para TESTE: Use token que comece com TEST-
# - Para PRODUÇÃO: Use token que comece com APP_USR-
# - Obtenha em: https://www.mercadopago.com.br/developers/panel/credentials
# - NUNCA exponha este token no frontend
#
# ⚠️ ATENÇÃO PARA TESTES EM SANDBOX:
# Se você usar um token APP_USR- (produção), os pagamentos de teste FALHARÃO
# mesmo que o sandbox_init_point seja gerado. Use um token TEST- para sandbox.
#
# EXEMPLO CORRETO PARA TESTES:
# MP_ACCESS_TOKEN=TEST-1234567890123456-010100-abcdef1234567890abcdef1234567890-123456789
#
# EXEMPLO ATUAL (PRODUÇÃO - NÃO FUNCIONA EM SANDBOX):
MP_ACCESS_TOKEN=TEST-your_mercadopago_token_here

# [MERCADO PAGO DEBUG] URL do site
# Usado para construir URLs de retorno (sucesso/falha) e webhook
# IMPORTANTE: Não incluir barra (/) no final
NEXT_PUBLIC_SITE_URL=https://www.voltrisoptimizer.com

# ========================================
# SUPABASE
# ========================================

# URL do projeto Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url

# Chave pública (anon key) do Supabase
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Chave de serviço (service role) do Supabase
# IMPORTANTE: Apenas usar no backend, nunca expor no frontend
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ========================================
# NODE.JS
# ========================================

# Versão do Node.js
NODE_VERSION=22.x

# PagBank Credentials
# Docs: https://dev.pagbank.uol.com.br/reference/autenticacao
PAGBANK_ENV="sandbox"
PAGBANK_TOKEN="YOUR_PAGBANK_TOKEN_HERE"
PAGBANK_WEBHOOK_AUTH_TOKEN="YOUR_SECURE_RANDOM_TOKEN_HERE"

# ========================================
# WEB PUSH (VAPID)
# Gere com: npx web-push generate-vapid-keys
# ========================================
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here

# ========================================
# LICENÇA
# Chave secreta para geração de licenças (deve ser igual ao C# LicenseGenerator)
# ========================================
LICENSE_SECRET_KEY=your_license_secret_key_here

# URL base do site (sem barra no final)
NEXT_PUBLIC_BASE_URL=https://www.voltrisoptimizer.com
