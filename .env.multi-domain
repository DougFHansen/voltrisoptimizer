# Configuração para manter ambos domínios ativos
NEXT_PUBLIC_SITE_URL=https://voltrisoptimizer.com
NEXT_PUBLIC_DOMAIN=voltrisoptimizer.com
NEXT_PUBLIC_LEGACY_URL=https://voltris.com.br

# OAuth para ambos domínios
SUPABASE_AUTH_EXTERNAL_GOOGLE_REDIRECT_URI=https://voltrisoptimizer.com/auth/callback

# URLs de redirect para ambos domínios
SUPABASE_REDIRECT_URLS=https://voltris.com.br/auth/callback,https://voltrisoptimizer.com/auth/callback,https://voltrisoptimizer.com/en/auth/callback,https://voltrisoptimizer.com/es/auth/callback,https://voltrisoptimizer.com/fr/auth/callback,https://voltrisoptimizer.com/de/auth/callback,https://voltrisoptimizer.com/it/auth/callback,https://voltrisoptimizer.com/ja/auth/callback,https://voltrisoptimizer.com/ko/auth/callback,https://voltrisoptimizer.com/ar/auth/callback
